# yuleCommunity API Server 环境配置
#
# 配置方式: 复制本文件为 .env 后修改
# cp .env.example .env

# 数据库连接 (PostgreSQL)
# 默认值与 docker-compose.yml 中定义的一致
DATABASE_URL=postgresql://yulecommunity:yulecommunity@localhost:5432/yulecommunity

# 或者用拆分配置 (DATABASE_URL 优先)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=yulecommunity
# PGUSER=yulecommunity
# PGPASSWORD=yulecommunity

# 服务器端口
PORT=3000

# JWT 密钥 (生产环境请修改为随机字符串)
JWT_SECRET=yulecommunity-dev-secret-2026

# 前端地址 (CORS)
# 如果是 GitHub Pages 部署，请设置:
# CORS_ORIGIN=https://frisky1985.github.io
